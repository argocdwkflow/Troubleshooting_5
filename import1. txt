#!/bin/bash
set -euo pipefail

CSV="/root/export_import/repos_export_with_published_v2_2.csv"
ORG_TARGET="BP2I Linux"
LOG="/root/import_repos.log"

DRY_RUN="yes"
SYNC_AFTER_CREATE="no"

: > "$LOG"

log() {
 echo "[$(date '+%F %T')] $*" | tee -a "$LOG"
}

run_cmd() {
 if [[ "$DRY_RUN" == "yes" ]]; then
  echo "[DRY RUN] $*" | tee -a "$LOG"
 else
  eval "$@" 2>&1 | tee -a "$LOG"
 fi
}

log "Import CSV: $CSV"
log "Organisation: $ORG_TARGET"

HEADER=$(head -1 "$CSV")

IFS=',' read -ra COLS <<< "$HEADER"

declare -A MAP

for i in "${!COLS[@]}"
do
 COL=$(echo "${COLS[$i]}" | tr -d '"')
 MAP[$COL]=$i
done

tail -n +2 "$CSV" | while IFS=',' read -ra LINE
do

 NAME=$(echo "${LINE[${MAP[NAME]}]}" | tr -d '"')
 LABEL=$(echo "${LINE[${MAP[LABEL]}]}" | tr -d '"')
 CONTENT_TYPE=$(echo "${LINE[${MAP[CONTENT_TYPE]}]}" | tr -d '"')
 MIRRORING_POLICY=$(echo "${LINE[${MAP[MIRRORING_POLICY]}]}" | tr -d '"')
 DOWNLOAD_POLICY=$(echo "${LINE[${MAP[DOWNLOAD_POLICY]}]}" | tr -d '"')
 PRODUCT_NAME=$(echo "${LINE[${MAP[PRODUCT_NAME]}]}" | tr -d '"')
 HTTP_PROXY_NAME=$(echo "${LINE[${MAP[HTTP_PROXY_NAME]}]}" | tr -d '"')
 HTTP_PROXY_POLICY=$(echo "${LINE[${MAP[HTTP_PROXY_POLICY]}]}" | tr -d '"')
 PUBLISHED_AT=$(echo "${LINE[${MAP[PUBLISHED_AT]}]}" | tr -d '"')

 if [[ -z "$NAME" || -z "$PRODUCT_NAME" || -z "$PUBLISHED_AT" ]]
 then
  log "Ligne ignorée: $NAME"
  continue
 fi

 log "Product: $PRODUCT_NAME"
 log "Repo: $NAME"

 if ! hammer --no-headers product list \
  --organization "$ORG_TARGET" \
  --search "name=\"$PRODUCT_NAME\"" | grep -q .
 then

  run_cmd "hammer product create \
   --organization \"$ORG_TARGET\" \
   --name \"$PRODUCT_NAME\""

 fi

 CMD="hammer repository create \
 --organization \"$ORG_TARGET\" \
 --product \"$PRODUCT_NAME\" \
 --name \"$NAME\" \
 --label \"$LABEL\" \
 --content-type \"$CONTENT_TYPE\" \
 --url \"$PUBLISHED_AT\""

 if [[ -n "$DOWNLOAD_POLICY" ]]
 then
  CMD="$CMD --download-policy \"$DOWNLOAD_POLICY\""
 fi

 if [[ -n "$MIRRORING_POLICY" ]]
 then
  CMD="$CMD --mirroring-policy \"$MIRRORING_POLICY\""
 fi

 if [[ -n "$HTTP_PROXY_POLICY" ]]
 then
  CMD="$CMD --http-proxy-policy \"$HTTP_PROXY_POLICY\""
 fi

 if [[ "$HTTP_PROXY_POLICY" == "use_selected_http_proxy" && -n "$HTTP_PROXY_NAME" ]]
 then
  CMD="$CMD --http-proxy \"$HTTP_PROXY_NAME\""
 fi

 run_cmd "$CMD"

 if [[ "$SYNC_AFTER_CREATE" == "yes" ]]
 then
  run_cmd "hammer repository synchronize \
  --organization \"$ORG_TARGET\" \
  --product \"$PRODUCT_NAME\" \
  --name \"$NAME\""
 fi

done

log "Import terminé"