2️⃣ Créer la règle udev NVMe
Bash
Copy code
cat <<'EOF' > /etc/udev/rules.d/60-nvme-performance.rules
# NVMe performance tuning for database workloads
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/read_ahead_kb}="4096"
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/rq_affinity}="2"
ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/io_poll}="1"
EOF
