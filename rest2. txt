Voici une version courte orientée reboot-safety.
Bash
Copy code
cat <<'EOF' > /root/reboot-safety-check.sh
#!/bin/bash

echo "=================================================="
echo " REBOOT SAFETY CHECK"
echo " Host   : $(hostname)"
echo " Date   : $(date)"
echo " Kernel : $(uname -r)"
echo "=================================================="
echo

echo "===== 1. RAID / LVM SYNC ====="
lvs -a -o lv_name,vg_name,segtype,sync_percent,devices
echo

echo "===== 2. FILESYSTEM MOUNTS ====="
findmnt -t xfs,ext4
echo

echo "===== 3. FSTAB TEST ====="
mount -a && echo "mount -a : OK" || echo "mount -a : FAILED"
echo

echo "===== 4. DISK SPACE ====="
df -hT
echo

echo "===== 5. PV / VG / LV ====="
pvs
vgs
lvs
echo

echo "===== 6. FAILED SERVICES ====="
systemctl --failed --no-pager
echo

echo "===== 7. LAST ERRORS ====="
journalctl -p err -n 30 --no-pager
echo

echo "===== 8. NVMe TUNING ====="
for d in /sys/block/nvme*n1; do
  [ -e "$d" ] || continue
  echo "--- $(basename "$d") ---"
  [ -f "$d/queue/read_ahead_kb" ] && echo "read_ahead_kb: $(cat "$d/queue/read_ahead_kb")"
  [ -f "$d/queue/rq_affinity" ] && echo "rq_affinity  : $(cat "$d/queue/rq_affinity")"
  [ -f "$d/queue/io_poll" ] && echo "io_poll      : $(cat "$d/queue/io_poll")"
  [ -f "$d/queue/scheduler" ] && echo "scheduler    : $(cat "$d/queue/scheduler")"
  echo
done

echo "===== 9. XFS INFO ====="
for m in $(findmnt -t xfs -n -o TARGET); do
  echo "--- $m ---"
  xfs_info "$m" 2>/dev/null
  echo
done

echo "===== 10. FINAL STATUS ====="
echo "Reboot OK only if:"
echo " - mount -a = OK"
echo " - RAID1 Sync% = 100.00"
echo " - no critical failed service"
echo " - filesystems visible in findmnt/df"
echo
echo "=================================================="
EOF

chmod +x /root/reboot-safety-check.sh
Exécution :
Bash
Copy code
/root/reboot-safety-check.sh
Pour sauvegarder le résultat :
Bash
Copy code
/root/reboot-safety-check.sh | tee /root/reboot-safety-check-$(date +%F-%H%M).log
Le critère principal avant reboot dans ton cas reste : mount -a sans erreur et Sync% = 100.00 sur les LV raid1.