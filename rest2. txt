Voici une version plus avancée sous forme de script storage-health-check.sh prête à copier-coller.
Bash
Copy code
cat <<'EOF' > /root/storage-health-check.sh
#!/bin/bash

echo "============================================================"
echo " STORAGE HEALTH CHECK - NVMe / LVM / XFS / DB"
echo " Host   : $(hostname)"
echo " Date   : $(date)"
echo " Kernel : $(uname -r)"
echo "============================================================"
echo

echo "===== 1. BLOCK DEVICES ====="
lsblk -d -o NAME,SIZE,MODEL,ROTA,SCHED,RA,PHY-SEC,LOG-SEC
echo

echo "===== 2. NVMe QUEUE PARAMETERS ====="
for d in /sys/block/nvme*n1; do
  [ -e "$d" ] || continue
  dev="$(basename "$d")"
  echo "--- $dev ---"
  for f in read_ahead_kb rq_affinity io_poll io_poll_delay rotational \
           max_sectors_kb minimum_io_size optimal_io_size physical_block_size \
           logical_block_size write_cache; do
    if [ -f "$d/queue/$f" ]; then
      printf "%-22s : %s\n" "$f" "$(cat "$d/queue/$f" 2>/dev/null)"
    fi
  done
  if [ -f "$d/queue/scheduler" ]; then
    printf "%-22s : %s\n" "scheduler" "$(cat "$d/queue/scheduler" 2>/dev/null)"
  else
    printf "%-22s : %s\n" "scheduler" "not exposed (often normal on NVMe)"
  fi
  echo
done

echo "===== 3. PARTITIONS / FILESYSTEM TREE ====="
lsblk -f
echo

echo "===== 4. LVM PHYSICAL VOLUMES ====="
pvs
echo

echo "===== 5. LVM VOLUME GROUPS ====="
vgs
echo

echo "===== 6. LVM LOGICAL VOLUMES ====="
lvs -a -o lv_name,vg_name,lv_size,segtype,lv_attr,copy_percent,sync_percent,devices
echo

echo "===== 7. MOUNTED FILESYSTEMS ====="
findmnt -t xfs,ext4
echo

echo "===== 8. XFS DETAILS ====="
for m in $(findmnt -t xfs -n -o TARGET); do
  echo "--- Mountpoint: $m ---"
  xfs_info "$m" 2>/dev/null
  echo
done

echo "===== 9. FSTAB ====="
grep -Ev '^\s*#|^\s*$' /etc/fstab
echo

echo "===== 10. SYSCTL DB PARAMETERS ====="
sysctl vm.swappiness \
       vm.dirty_ratio \
       vm.dirty_background_ratio \
       vm.dirty_expire_centisecs \
       vm.dirty_writeback_centisecs 2>/dev/null
echo

echo "===== 11. UDEV NVMe RULES ====="
grep -R "nvme" /etc/udev/rules.d /usr/lib/udev/rules.d 2>/dev/null
echo

echo "===== 12. RAID / MIRROR STATE ====="
lvs -a -o lv_name,vg_name,segtype,sync_percent,devices | egrep 'raid|mirror|LV'
echo

echo "===== 13. DISK USAGE ====="
df -hT
echo

echo "===== 14. CURRENT I/O SNAPSHOT ====="
if command -v iostat >/dev/null 2>&1; then
  iostat -dxm 1 2
else
  echo "iostat not installed (package: sysstat)"
fi
echo

echo "===== 15. FAILED SYSTEMD UNITS ====="
systemctl --failed --no-pager
echo

echo "===== 16. BOOT / MOUNT SAFETY CHECK ====="
echo "--- mount -a test ---"
mount -a && echo "mount -a : OK" || echo "mount -a : FAILED"
echo

echo "===== 17. SUMMARY HINTS ====="
echo "- Check Sync% = 100.00 for RAID1 LVM before reboot."
echo "- Check XFS sunit/swidth values match expected alignment."
echo "- Check read_ahead_kb, rq_affinity, io_poll for NVMe tuning."
echo "- Check mount -a returns no error."
echo "- Check no critical failed units before reboot."
echo
echo "============================================================"
echo " END OF REPORT"
echo "============================================================"
EOF

chmod +x /root/storage-health-check.sh
Exécution :
Bash
Copy code
/root/storage-health-check.sh
Pour sauvegarder le rapport :
Bash
