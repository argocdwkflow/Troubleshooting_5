Copy code
echo "===== NVMe Devices ====="
lsblk -d -o NAME,ROTA,SCHED,RA,DISC-MAX,DISC-GRAN

echo
echo "===== NVMe Queue Parameters ====="
for d in /sys/block/nvme*n1; do
  echo "--- $d ---"
  printf "read_ahead_kb : %s\n" "$(cat $d/queue/read_ahead_kb 2>/dev/null)"
  printf "rq_affinity   : %s\n" "$(cat $d/queue/rq_affinity 2>/dev/null)"
  printf "io_poll       : %s\n" "$(cat $d/queue/io_poll 2>/dev/null)"
  printf "scheduler     : %s\n" "$(cat $d/queue/scheduler 2>/dev/null)"
  echo
done

echo "===== LVM Layout ====="
pvs
vgs
