#!/bin/bash
set -Eeuo pipefail

ORG=""

CV_CSV="content_views_full.csv"
CV_REPO_CSV="content_view_repositories.csv"
CCV_COMPONENTS_CSV="ccv_components.csv"

LOG_FILE="/tmp/import_all_cv_ccv.log"

exec > >(tee -a "${LOG_FILE}") 2>&1

echo "=============================================================="
echo " Import CV / CCV with same name and same label"
echo " Organization : ${ORG}"
echo " Started at   : $(date)"
echo "=============================================================="

command -v hammer >/dev/null 2>&1 || {
  echo "ERROR: hammer command not found"
  exit 1
}

[ -f "${CV_CSV}" ] || { echo "ERROR: missing file ${CV_CSV}"; exit 1; }
[ -f "${CV_REPO_CSV}" ] || { echo "ERROR: missing file ${CV_REPO_CSV}"; exit 1; }
[ -f "${CCV_COMPONENTS_CSV}" ] || { echo "ERROR: missing file ${CCV_COMPONENTS_CSV}"; exit 1; }

csv_unquote() {
  local s="${1:-}"
  s="${s%\"}"
  s="${s#\"}"
  s="${s//\"\"/\"}"
  printf '%s' "$s"
}

get_cv_id_by_name() {
  local cv_name="$1"
  hammer --csv content-view list --organization "${ORG}" 2>/dev/null \
    | tail -n +2 \
    | awk -F, -v target="$cv_name" '
      {
        id=$1
        name=$2
        gsub(/^"|"$/, "", id)
        gsub(/^"|"$/, "", name)
        if (name == target) {
          print id
          exit
        }
      }'
}

get_cv_id_by_label() {
  local cv_label="$1"
  hammer --csv content-view list --organization "${ORG}" 2>/dev/null \
    | tail -n +2 \
    | awk -F, -v target="$cv_label" '
      {
        id=$1
        label=$3
        gsub(/^"|"$/, "", id)
        gsub(/^"|"$/, "", label)
        if (label == target) {
          print id
          exit
        }
      }'
}

get_repo_id_by_name() {
  local repo_name="$1"
  hammer --csv repository list --organization "${ORG}" --search "name=\"${repo_name}\"" 2>/dev/null \
    | tail -n +2 \
    | awk -F, '
      {
        id=$1
        gsub(/^"|"$/, "", id)
        print id
        exit
      }'
}

cv_has_repository() {
  local cv_id="$1"
  local repo_id="$2"

  hammer content-view info --organization "${ORG}" --id "${cv_id}" 2>/dev/null \
    | awk -v target="${repo_id}" '
      /^[[:space:]]*[0-9]+\)[[:space:]]*Id:[[:space:]]*/ {
        line=$0
        sub(/^[[:space:]]*[0-9]+\)[[:space:]]*Id:[[:space:]]*/, "", line)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
        if (line == target) {
          found=1
          exit
        }
      }
      /^[[:space:]]*Id:[[:space:]]*/ {
        line=$0
        sub(/^[[:space:]]*Id:[[:space:]]*/, "", line)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
        if (line == target) {
          found=1
          exit
        }
      }
      END {
        if (found) exit 0
        exit 1
      }'
}

ccv_has_component() {
  local ccv_id="$1"
  local component_name="$2"

  hammer --csv content-view component list \
    --organization "${ORG}" \
    --content-view-id "${ccv_id}" 2>/dev/null \
    | tail -n +2 \
    | awk -F, -v target="${component_name}" '
      {
        name=$2
        gsub(/^"|"$/, "", name)
        if (name == target) {
          found=1
          exit
        }
      }
      END {
        if (found) exit 0
        exit 1
      }'
}

create_cv_objects() {
  echo
  echo "==================== STEP 1 - CREATE CV ===================="

  tail -n +2 "${CV_CSV}" | while IFS=',' read -r cv_id name label composite description host_count solve_deps organization; do
    CV_NAME="$(csv_unquote "${name}")"
    CV_LABEL="$(csv_unquote "${label}")"
    CV_COMPOSITE="$(csv_unquote "${composite}")"
    CV_DESC="$(csv_unquote "${description}")"

    [ -z "${CV_NAME}" ] && continue
    [ "${CV_COMPOSITE}" = "yes" ] && continue

    echo
    echo "CV source      : ${CV_NAME}"
    echo "CV label       : ${CV_LABEL}"

    EXISTING_BY_NAME="$(get_cv_id_by_name "${CV_NAME}")"
    EXISTING_BY_LABEL="$(get_cv_id_by_label "${CV_LABEL}")"

    if [ -n "${EXISTING_BY_NAME}" ] || [ -n "${EXISTING_BY_LABEL}" ]; then
      echo "Already exists on target"
      echo "  by name  : ${EXISTING_BY_NAME:-none}"
      echo "  by label : ${EXISTING_BY_LABEL:-none}"

      if [ -n "${EXISTING_BY_NAME}" ] && [ -n "${EXISTING_BY_LABEL}" ] && [ "${EXISTING_BY_NAME}" = "${EXISTING_BY_LABEL}" ]; then
        echo "OK: same CV already present"
        continue
      fi

      echo "WARN: name/label conflict detected, skipping creation"
      continue
    fi

    echo "Creating CV with same name and label"

    if [ -n "${CV_DESC}" ]; then
      hammer content-view create \
        --organization "${ORG}" \
        --name "${CV_NAME}" \
        --label "${CV_LABEL}" \
        --description "${CV_DESC}"
    else
      hammer content-view create \
        --organization "${ORG}" \
        --name "${CV_NAME}" \
        --label "${CV_LABEL}"
    fi
  done
}

attach_repositories_to_cv() {
  echo
  echo "================ STEP 2 - ADD REPOSITORIES TO CV ================="

  tail -n +2 "${CV_REPO_CSV}" | while IFS=',' read -r src_cv_id src_cv_name src_cv_label repo_id repo_name repo_label; do
    CV_NAME="$(csv_unquote "${src_cv_name}")"
    REPO_NAME="$(csv_unquote "${repo_name}")"

    [ -z "${CV_NAME}" ] && continue
    [ -z "${REPO_NAME}" ] && continue

    TARGET_CV_ID="$(get_cv_id_by_name "${CV_NAME}")"
    if [ -z "${TARGET_CV_ID}" ]; then
      echo "WARN: target CV not found: ${CV_NAME}"
      continue
    fi

    TARGET_REPO_ID="$(get_repo_id_by_name "${REPO_NAME}")"
    if [ -z "${TARGET_REPO_ID}" ]; then
      echo "WARN: target repository not found by name: ${REPO_NAME}"
      continue
    fi

    if cv_has_repository "${TARGET_CV_ID}" "${TARGET_REPO_ID}"; then
      echo "Repository already attached: CV='${CV_NAME}' repo='${REPO_NAME}'"
      continue
    fi

    echo "Adding repository to CV"
    echo "  CV   : ${CV_NAME} (ID=${TARGET_CV_ID})"
    echo "  Repo : ${REPO_NAME} (ID=${TARGET_REPO_ID})"

    hammer content-view add-repository \
      --organization "${ORG}" \
      --id "${TARGET_CV_ID}" \
      --repository-id "${TARGET_REPO_ID}"
  done
}

create_ccv_objects() {
  echo
  echo "==================== STEP 3 - CREATE CCV ===================="

  tail -n +2 "${CV_CSV}" | while IFS=',' read -r cv_id name label composite description host_count solve_deps organization; do
    CCV_NAME="$(csv_unquote "${name}")"
    CCV_LABEL="$(csv_unquote "${label}")"
    CV_COMPOSITE="$(csv_unquote "${composite}")"
    CCV_DESC="$(csv_unquote "${description}")"

    [ -z "${CCV_NAME}" ] && continue
    [ "${CV_COMPOSITE}" != "yes" ] && continue

    echo
    echo "CCV source     : ${CCV_NAME}"
    echo "CCV label      : ${CCV_LABEL}"

    EXISTING_BY_NAME="$(get_cv_id_by_name "${CCV_NAME}")"
    EXISTING_BY_LABEL="$(get_cv_id_by_label "${CCV_LABEL}")"

    if [ -n "${EXISTING_BY_NAME}" ] || [ -n "${EXISTING_BY_LABEL}" ]; then
      echo "Already exists on target"
      echo "  by name  : ${EXISTING_BY_NAME:-none}"
      echo "  by label : ${EXISTING_BY_LABEL:-none}"

      if [ -n "${EXISTING_BY_NAME}" ] && [ -n "${EXISTING_BY_LABEL}" ] && [ "${EXISTING_BY_NAME}" = "${EXISTING_BY_LABEL}" ]; then
        echo "OK: same CCV already present"
        continue
      fi

      echo "WARN: name/label conflict detected, skipping creation"
      continue
    fi

    echo "Creating CCV with same name and label"

    if [ -n "${CCV_DESC}" ]; then
      hammer content-view create \
        --organization "${ORG}" \
        --name "${CCV_NAME}" \
        --label "${CCV_LABEL}" \
        --description "${CCV_DESC}" \
        --composite
    else
      hammer content-view create \
        --organization "${ORG}" \
        --name "${CCV_NAME}" \
        --label "${CCV_LABEL}" \
        --composite
    fi
  done
}

attach_components_to_ccv() {
  echo
  echo "================ STEP 4 - ADD COMPONENTS TO CCV ================="

  tail -n +2 "${CCV_COMPONENTS_CSV}" | while IFS=',' read -r ccv_name ccv_label component_cv_name; do
    CCV_NAME="$(csv_unquote "${ccv_name}")"
    COMPONENT_NAME="$(csv_unquote "${component_cv_name}")"

    [ -z "${CCV_NAME}" ] && continue
    [ -z "${COMPONENT_NAME}" ] && continue

    TARGET_CCV_ID="$(get_cv_id_by_name "${CCV_NAME}")"
    if [ -z "${TARGET_CCV_ID}" ]; then
      echo "WARN: target CCV not found: ${CCV_NAME}"
      continue
    fi

    TARGET_COMPONENT_ID="$(get_cv_id_by_name "${COMPONENT_NAME}")"
    if [ -z "${TARGET_COMPONENT_ID}" ]; then
      echo "WARN: target component CV not found: ${COMPONENT_NAME}"
      continue
    fi

    if ccv_has_component "${TARGET_CCV_ID}" "${COMPONENT_NAME}"; then
      echo "Component already attached: CCV='${CCV_NAME}' component='${COMPONENT_NAME}'"
      continue
    fi

    echo "Adding component to CCV"
    echo "  CCV       : ${CCV_NAME} (ID=${TARGET_CCV_ID})"
    echo "  Component : ${COMPONENT_NAME} (ID=${TARGET_COMPONENT_ID})"

    hammer content-view component add \
      --organization "${ORG}" \
      --composite-content-view-id "${TARGET_CCV_ID}" \
      --content-view-id "${TARGET_COMPONENT_ID}" \
      --latest
  done
}

create_cv_objects
attach_repositories_to_cv
create_ccv_objects
attach_components_to_ccv

echo
echo "=============================================================="
echo "Import finished at : $(date)"
echo "Log file           : ${LOG_FILE}"
echo "=============================================================="