#!/bin/ksh
# Temporary CleanProgram for isi-p-APP
# Force cleanup after failure

BASE="/appli/cluster/SG-isi-p"
RUN="${BASE}/run"
PIDFILE="${RUN}/isi-p.pid"
LOG="${BASE}/logs/isi-p_app.log"

echo "$(date) CLEAN started" >> "${LOG}"

# If pidfile exists, try to kill process
if [ -f "${PIDFILE}" ]; then
    PID="$(cat "${PIDFILE}" 2>/dev/null)"

    if [ -n "${PID}" ] && kill -0 "${PID}" 2>/dev/null; then
        echo "$(date) CLEAN killing pid=${PID}" >> "${LOG}"
        kill -9 "${PID}" 2>/dev/null
        sleep 1
    fi

    rm -f "${PIDFILE}"
fi

echo "$(date) CLEAN finished" >> "${LOG}"
exit 0
