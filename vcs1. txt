#!/bin/ksh
# Temporary VCS StopProgram for isi-p-APP
# Stops the marker process gracefully then forcefully if needed.

BASE="/appli/cluster/SG-isi-p"
RUN="${BASE}/run"
PIDFILE="${RUN}/isi-p.pid"
LOG="${BASE}/logs/isi-p_app.log"

# Nothing to stop
if [ ! -f "${PIDFILE}" ]; then
  echo "$(date) no pidfile - already stopped" >> "${LOG}"
  exit 0
fi

PID="$(cat "${PIDFILE}" 2>/dev/null)"

# If pid invalid or not running => clean pidfile and exit OK
if [ -z "${PID}" ] || ! kill -0 "${PID}" 2>/dev/null; then
  echo "$(date) pid not running - cleaning pidfile" >> "${LOG}"
  rm -f "${PIDFILE}"
  exit 0
fi

echo "$(date) stopping pid=${PID}" >> "${LOG}"

# Try graceful stop
kill "${PID}" 2>/dev/null

# Wait up to 30s
i=0
while [ $i -lt 30 ]; do
  if ! kill -0 "${PID}" 2>/dev/null; then
    rm -f "${PIDFILE}"
    echo "$(date) stopped" >> "${LOG}"
    exit 0
  fi
  sleep 1
  i=$((i+1))
done

# Force kill
echo "$(date) force killing pid=${PID}" >> "${LOG}"
kill -9 "${PID}" 2>/dev/null
sleep 1

if kill -0 "${PID}" 2>/dev/null; then
  echo "$(date) still running after kill -9" >> "${LOG}"
  exit 1
fi

rm -f "${PIDFILE}"
echo "$(date) stopped after force" >> "${LOG}"
exit 0
