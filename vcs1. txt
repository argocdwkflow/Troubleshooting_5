#!/bin/ksh
# Temporary VCS StartProgram for isi-p-APP
# Starts a harmless marker process and stores its PID.

BASE="/appli/cluster/SG-isi-p"
RUN="${BASE}/run"
PIDFILE="${RUN}/isi-p.pid"
LOG="${BASE}/logs/isi-p_app.log"

mkdir -p "${RUN}" "${BASE}/logs"

# If already running, exit OK
if [ -f "${PIDFILE}" ] && kill -0 "$(cat "${PIDFILE}" 2>/dev/null)" 2>/dev/null; then
  echo "$(date) already running pid=$(cat "${PIDFILE}")" >> "${LOG}"
  exit 0
fi

# Start marker process (infinite sleep loop)
( while :; do sleep 60; done ) >> "${LOG}" 2>&1 &
PID=$!

echo "${PID}" > "${PIDFILE}"
sleep 1

# Validate it is running
if kill -0 "${PID}" 2>/dev/null; then
  echo "$(date) started pid=${PID}" >> "${LOG}"
  exit 0
else
  echo "$(date) failed to start" >> "${LOG}"
  rm -f "${PIDFILE}"
  exit 1
fi
