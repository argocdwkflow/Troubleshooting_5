#!/bin/ksh
# Temporary VCS MonitorProgram for isi-p-APP
# Exit codes: 0=ONLINE, 100=OFFLINE/FAULT

BASE="/appli/cluster/SG-isi-p"
RUN="${BASE}/run"
PIDFILE="${RUN}/isi-p.pid"

if [ -f "${PIDFILE}" ]; then
  PID="$(cat "${PIDFILE}" 2>/dev/null)"
  if [ -n "${PID}" ] && kill -0 "${PID}" 2>/dev/null; then
    exit 0
  fi
fi

exit 100
