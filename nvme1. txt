6️⃣ Créer filesystem
Pour base de données :
Bash
Copy code
mkfs.xfs -f /dev/vg_tempdb/lv_ESY3_FR_UAT_ASE_sybtemp
mkfs.xfs -f /dev/vg_tempdb/lv_ESY3_FR_UAT_ASE_sybtpmp
7️⃣ Créer les mountpoints
Bash
Copy code
mkdir -p /apps/sybase/dump/ESY3_FR_UAT_ASE
mkdir -p /apps/sybasetmp/ESY3_FR_UAT_ASE
8️⃣ Monter les FS
Bash
Copy code
mount /dev/vg_tempdb/lv_ESY3_FR_UAT_ASE_sybtemp /apps/sybase/dump/ESY3_FR_UAT_ASE
mount /dev/vg_tempdb/lv_ESY3_FR_UAT_ASE_sybtpmp /apps/sybasetmp/ESY3_FR_UAT_ASE
