#!/bin/bash
set -euo pipefail

ORG="BP2I Linux"
OUT="/root/repos_export_with_published.csv"

echo '"ORGANIZATION_NAME","MIRRORING_POLICY","NAME","LABEL","CONTENT_TYPE","CONTENT_LABEL","URL","PUBLISHED_AT"' > "$OUT"

hammer --no-headers --csv repository list \
  --organization "$ORG" \
  --fields "Id" | tr -d '"' | while read -r ID
do
  hammer repository info --id "$ID" | awk -F': ' '
    BEGIN {
      org=""; mpolicy=""; name=""; label="";
      ctype=""; clabel=""; url=""; published=""
    }
    /^Organization:/    {org=$2}
    /^Mirroring Policy:/ {mpolicy=$2}
    /^Name:/ && name=="" {name=$2}
    /^Label:/           {label=$2}
    /^Content Type:/    {ctype=$2}
    /^Content Label:/   {clabel=$2}
    /^Url:/             {url=$2}
    /^Published At:/    {published=$2}
    END {
      gsub(/"/, "\"\"", org)
      gsub(/"/, "\"\"", mpolicy)
      gsub(/"/, "\"\"", name)
      gsub(/"/, "\"\"", label)
      gsub(/"/, "\"\"", ctype)
      gsub(/"/, "\"\"", clabel)
      gsub(/"/, "\"\"", url)
      gsub(/"/, "\"\"", published)

      printf "\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\"\n",
             org, mpolicy, name, label, ctype, clabel, url, published
    }
  ' >> "$OUT"
done

echo "Fichier généré : $OUT"
