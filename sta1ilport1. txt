3) Script import sur le Satellite cible
Je te donne une version qui lit exactement ces colonnes et crée les repositories avec :
name
content-type
url = published_at
Le label, content label et mirroring policy sont exportés pour inventaire et contrôle.
En pratique, pour hammer repository create, les paramètres réellement utiles sont surtout name, content-type, url.
Le label du repo est généralement généré automatiquement à partir du nom.
Bash
Copy code
#!/bin/bash
set -euo pipefail

CSV="/root/repos_export_with_published.csv"
ORG_TARGET="BP2I Linux"
PRODUCT_TARGET="SATELLITE-UPSTREAM"

product_exists() {
  hammer --no-headers product list \
    --organization "$ORG_TARGET" \
    --search "name=\"$PRODUCT_TARGET\"" | grep -q .
}

repo_exists() {
  local repo="$1"
  hammer --no-headers repository list \
    --organization "$ORG_TARGET" \
    --product "$PRODUCT_TARGET" \
    --search "name=\"$repo\"" | grep -q .
}

if ! product_exists; then
  echo "Création product : $PRODUCT_TARGET"
  hammer product create \
    --organization "$ORG_TARGET" \
    --name "$PRODUCT_TARGET"
fi

tail -n +2 "$CSV" | while IFS=',' read -r ORGANIZATION_NAME MIRRORING_POLICY NAME LABEL CONTENT_TYPE CONTENT_LABEL URL PUBLISHED_AT
do
  ORGANIZATION_NAME=$(echo "$ORGANIZATION_NAME" | sed 's/^"//;s/"$//; s/""/"/g')
  MIRRORING_POLICY=$(echo "$MIRRORING_POLICY" | sed 's/^"//;s/"$//; s/""/"/g')
  NAME=$(echo "$NAME" | sed 's/^"//;s/"$//; s/""/"/g')
  LABEL=$(echo "$LABEL" | sed 's/^"//;s/"$//; s/""/"/g')
  CONTENT_TYPE=$(echo "$CONTENT_TYPE" | sed 's/^"//;s/"$//; s/""/"/g')
  CONTENT_LABEL=$(echo "$CONTENT_LABEL" | sed 's/^"//;s/"$//; s/""/"/g')
  URL=$(echo "$URL" | sed 's/^"//;s/"$//; s/""/"/g')
  PUBLISHED_AT=$(echo "$PUBLISHED_AT" | sed 's/^"//;s/"$//; s/""/"/g')

  if [[ -z "$NAME" || -z "$CONTENT_TYPE" || -z "$PUBLISHED_AT" ]]; then
    echo "Entrée ignorée : NAME=$NAME CONTENT_TYPE=$CONTENT_TYPE PUBLISHED_AT=$PUBLISHED_AT"
    continue
  fi

  if repo_exists "$NAME"; then
    echo "Repository déjà existant : $NAME"
    continue
  fi

  echo "Création repository : $NAME"
  echo "  Organization Name : $ORGANIZATION_NAME"
  echo "  Mirroring Policy  : $MIRRORING_POLICY"
  echo "  Label             : $LABEL"
  echo "  Content Type      : $CONTENT_TYPE"
  echo "  Content Label     : $CONTENT_LABEL"
  echo "  Source Url        : $URL"
  echo "  Upstream Url used : $PUBLISHED_AT"

  hammer repository create \
    --organization "$ORG_TARGET" \
    --product "$PRODUCT_TARGET" \
    --name "$NAME" \
    --content-type "$CONTENT_TYPE" \
    --url "$PUBLISHED_AT"
done
