- name: Run makecache without blocking install
  ansible.builtin.command: "{{ ansible_pkg_mgr }} -q makecache"
  register: makecache_result
  changed_when: false
  failed_when: false

- name: Show makecache stderr if any
  ansible.builtin.debug:
    var: makecache_result.stderr_lines
  when: makecache_result.rc != 0